{
  "name": "aura",
  "version": "1.3.0",
  "description": "Aura — persoonlijke gezondheids- en cyclus-tracker (PWA)",
  "private": true,
  "type": "module",
  "engines": {
    "node": ">=20.0.0",
    "npm": ">=10.0.0"
  },
  "scripts": {
    "build": "node build.mjs",
    "dev": "echo 'Open index.html directly in a browser — no build needed for dev mode.'",
    "test": "vitest run",
    "test:watch": "vitest",
    "audit": "node build.mjs && node scripts/audit-lighthouse.mjs --skip-build",
    "audit:quick": "node scripts/audit-lighthouse.mjs --skip-build",
    "gen:icon": "node scripts/generate-app-icon.mjs",
    "gen:splash": "node scripts/generate-splash.mjs",
    "preflight": "node scripts/preflight.mjs"
  },
  "dependencies": {
    "@fontsource-variable/fraunces": "^5.2.9",
    "@fontsource-variable/inter": "^5.2.8",
    "lucide-react": "0.441.0",
    "react": "18.3.1",
    "react-dom": "18.3.1"
  },
  "devDependencies": {
    "esbuild": "^0.25.12",
    "sharp": "^0.33.5",
    "tailwindcss": "3.4.13",
    "vitest": "^4.1.5"
  }
}
