{
  "name": "paced",
  "version": "1.3.0",
  "description": "Paced — persoonlijke gezondheids- en cyclus-tracker (PWA)",
  "private": true,
  "type": "module",
  "engines": {
    "node": ">=20.0.0",
    "npm": ">=10.0.0"
  },
  "scripts": {
    "build": "node build.mjs",
    "dev": "echo 'Open index.html directly in a browser — no build needed for dev mode.'",
    "test": "vitest run",
    "test:watch": "vitest",
    "audit": "node build.mjs && node scripts/audit-lighthouse.mjs --skip-build",
    "audit:quick": "node scripts/audit-lighthouse.mjs --skip-build",
    "content:tov": "node scripts/generate-tov.mjs",
    "content:templates": "node scripts/generate-templates.mjs",
    "content:regen": "node scripts/regen.mjs",
    "gen:icon": "node scripts/generate-app-icon.mjs",
    "gen:splash": "node scripts/generate-splash.mjs",
    "preflight": "node scripts/preflight.mjs",
    "ios:sync": "npm run build && npx cap sync ios",
    "ios:open": "npx cap open ios",
    "ios:assets": "npx capacitor-assets generate --ios"
  },
  "dependencies": {
    "@capacitor/core": "^7.0.0",
    "@capacitor/ios": "^7.0.0",
    "@fontsource-variable/fraunces": "^5.2.9",
    "@fontsource-variable/inter": "^5.2.8",
    "@sentry/browser": "^8.0.0",
    "@supabase/supabase-js": "^2.46.0",
    "lucide-react": "0.441.0",
    "react": "18.3.1",
    "react-dom": "18.3.1"
  },
  "devDependencies": {
    "@anthropic-ai/sdk": "^0.104.1",
    "@capacitor/assets": "^3.0.5",
    "@capacitor/cli": "^7.0.0",
    "esbuild": "^0.25.12",
    "sharp": "^0.33.5",
    "tailwindcss": "3.4.13",
    "vitest": "^4.1.5"
  }
}
