# syntax=docker/dockerfile:1
#
# OPTIONAL / ALTERNATIVE PATH — not the live build for paced.nl.
# Production ships static `dist/` via the Cloudflare Pages Git integration.
# Use this container only for: reproducible local prod-like preview,
# a future on-prem / data-sovereignty mandate, or CI build determinism.
#
# Multi-stage: esbuild build (node build.mjs) -> nginx static serve.

FROM node:20-alpine AS build
WORKDIR /app
COPY package.json package-lock.json ./
RUN npm ci
COPY . .
RUN npm run build          # node build.mjs -> dist/

FROM nginx:alpine
COPY --from=build /app/dist /usr/share/nginx/html
COPY nginx.conf.example /etc/nginx/conf.d/default.conf
EXPOSE 8080
HEALTHCHECK --interval=30s --timeout=3s CMD wget -qO- http://127.0.0.1:8080/ >/dev/null || exit 1
